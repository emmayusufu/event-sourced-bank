{
  "name": "event-sourced-bank",
  "private": true,
  "version": "0.1.0",
  "description": "Bank account service with CQRS and event sourcing on Postgres.",
  "author": "Emmanuel Kimaswa <kimaswaemma36@gmail.com>",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "uuid": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "testcontainers": "^10.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.2.4"
  }
}
